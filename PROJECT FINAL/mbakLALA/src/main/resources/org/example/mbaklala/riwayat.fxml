<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox style="-fx-background-color: #F0F4F8;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.mbaklala.admin.RiwayatController">
    <VBox prefWidth="380" spacing="15" style="-fx-padding: 30;">
        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e4581; -fx-font-family: 'Segoe UI';" text="Riwayat Transaksi" />
        <ListView fx:id="listRiwayat" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #BDC3C7; -fx-font-family: 'Segoe UI'; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 3);" VBox.vgrow="ALWAYS" />
    </VBox>

    <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 40; -fx-background-radius: 25 0 0 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.18), 25, -8, 0, 0);" HBox.hgrow="ALWAYS">

        <HBox alignment="CENTER_LEFT">
            <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e4581; -fx-font-family: 'Segoe UI';" text="Arsip Detail Pesanan">
                <padding>
                    <Insets right="10.0" />
                </padding></Label>
            <Region HBox.hgrow="ALWAYS" />
            <Label style="-fx-font-weight: bold; -fx-text-fill: #2ECC71; -fx-padding: 5 5 5 5; -fx-background-color: #EAFAF1; -fx-background-radius: 8; -fx-font-family: 'Segoe UI';" text="status: selesai" />
        </HBox>
        <Separator />

        <GridPane hgap="20" vgap="15">
            <columnConstraints>
                <ColumnConstraints minWidth="130" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <Label style="-fx-text-fill: #7F8C8D; -fx-font-family: 'Segoe UI';" text="ID Pesanan" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <Label fx:id="lblId" style="-fx-font-weight: bold; -fx-text-fill: #30a8d4; -fx-font-family: 'Segoe UI';" text="-" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label style="-fx-text-fill: #7F8C8D; -fx-font-family: 'Segoe UI';" text="Nama Pelanggan" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <Label fx:id="lblNama" style="-fx-font-weight: bold; -fx-text-fill: #30a8d4; -fx-font-family: 'Segoe UI';" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label style="-fx-text-fill: #7F8C8D; -fx-font-family: 'Segoe UI';" text="Nomor Kontak" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <Label fx:id="lblTelp" style="-fx-font-weight: bold; -fx-text-fill: #30a8d4; -fx-font-family: 'Segoe UI';" text="-" GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label style="-fx-text-fill: #7F8C8D; -fx-font-family: 'Segoe UI';" text="Alamat Pengiriman" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <Label fx:id="lblAlamat" style="-fx-font-weight: bold; -fx-text-fill: #30a8d4; -fx-font-family: 'Segoe UI';" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="3" />

            <Label style="-fx-text-fill: #7F8C8D; -fx-font-family: 'Segoe UI';" text="Metode Pembayaran" GridPane.columnIndex="0" GridPane.rowIndex="4" />
            <Label fx:id="lblMetodeBayar" style="-fx-font-weight: bold; -fx-text-fill: #1e4581; -fx-font-family: 'Segoe UI';" text="-" GridPane.columnIndex="1" GridPane.rowIndex="4" />

            <Label style="-fx-text-fill: #7F8C8D; -fx-font-family: 'Segoe UI';" text="Status Pembayaran" GridPane.columnIndex="0" GridPane.rowIndex="5" />
            <Label fx:id="lblStatusBayar" style="-fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="-" GridPane.columnIndex="1" GridPane.rowIndex="5" />

            <rowConstraints>
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
            </rowConstraints>
        </GridPane>

        <VBox spacing="5" style="-fx-background-color: #F8F9FA; -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: #E5E7E9; -fx-border-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 10, 0, 0, 4);">
            <Label style="-fx-text-fill: #1e4581; -fx-font-size: 13px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="Rincian Layanan &amp; Tagihan:" />
            <VBox fx:id="vboxLayananDetail" spacing="5">
                <VBox.margin><Insets bottom="10" top="5" /></VBox.margin>
            </VBox>
            <Separator />
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
                <Label style="-fx-text-fill: #30a8d4; -fx-font-size: 14px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="Total Pendapatan Transaksi:" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblTotal" style="-fx-font-weight: bold; -fx-font-size: 28px; -fx-text-fill: #c16cda; -fx-font-family: 'Segoe UI';" text="Rp -" />
            </HBox>
        </VBox>

        <Region VBox.vgrow="ALWAYS" />

        <HBox alignment="CENTER_RIGHT">
            <Button onAction="#handleKembali" style="-fx-background-color: white; -fx-border-color: #BDC3C7; -fx-text-fill: #7F8C8D; -fx-cursor: hand; -fx-border-radius: 8; -fx-padding: 10 25; -fx-font-family: 'Segoe UI'; -fx-font-weight: bold; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.12), 10, 0, 0, 3);" text="Kembali ke Dashboard" />
        </HBox>
    </VBox>
</HBox>