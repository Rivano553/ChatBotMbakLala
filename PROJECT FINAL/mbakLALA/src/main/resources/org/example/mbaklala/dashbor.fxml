<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="18" style="-fx-background-color: #F0F4F8;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.mbaklala.admin.AdminController">
    <padding><Insets bottom="25" left="40" right="40" top="25" /></padding>

    <HBox alignment="CENTER_LEFT">
        <Label text="Dashboard Admin" style="-fx-font-size: 24px; -fx-text-fill: #1e4581; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Keluar" onAction="#handleLogout" style="-fx-background-color: white; -fx-border-color: #BDC3C7; -fx-text-fill: #7F8C8D; -fx-border-radius: 6; -fx-padding: 6 20; -fx-cursor: hand; -fx-font-weight: bold; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 8, 0, 0, 2);" />
    </HBox>

    <FlowPane hgap="12" vgap="12" alignment="CENTER">

        <VBox alignment="CENTER" prefWidth="145" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.12), 15, 0, 0, 5); -fx-border-width: 0 0 4 0; -fx-border-color: #c16cda;">
            <Label text="Menunggu Jemput" style="-fx-text-fill: #7F8C8D; -fx-font-size: 11px; -fx-font-weight: 500;"/>
            <Label fx:id="lblJemput" text="0" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e4581;" />
        </VBox>

        <VBox alignment="CENTER" prefWidth="145" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.12), 15, 0, 0, 5); -fx-border-width: 0 0 4 0; -fx-border-color: #c16cda;">
            <Label text="Antre Cuci" style="-fx-text-fill: #7F8C8D; -fx-font-size: 11px; -fx-font-weight: 500;"/>
            <Label fx:id="lblAntre" text="0" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e4581;" />
        </VBox>

        <VBox alignment="CENTER" prefWidth="145" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.12), 15, 0, 0, 5); -fx-border-width: 0 0 4 0; -fx-border-color: #c16cda;">
            <Label text="Proses Cuci" style="-fx-text-fill: #7F8C8D; -fx-font-size: 11px; -fx-font-weight: 500;"/>
            <Label fx:id="lblProses" text="0" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e4581;" />
        </VBox>

        <VBox alignment="CENTER" prefWidth="145" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.12), 15, 0, 0, 5); -fx-border-width: 0 0 4 0; -fx-border-color: #c16cda;">
            <Label text="Siap Antar" style="-fx-text-fill: #7F8C8D; -fx-font-size: 11px; -fx-font-weight: 500;"/>
            <Label fx:id="lblSiap" text="0" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e4581;" />
        </VBox>

        <VBox alignment="CENTER" prefWidth="145" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.12), 15, 0, 0, 5); -fx-border-width: 0 0 4 0; -fx-border-color: #c16cda;">
            <Label text="Sedang Diantar" style="-fx-text-fill: #7F8C8D; -fx-font-size: 11px; -fx-font-weight: 500;"/>
            <Label fx:id="lblDiantar" text="0" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e4581;" />
        </VBox>

        <VBox alignment="CENTER" prefWidth="145" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.12), 15, 0, 0, 5); -fx-border-width: 0 0 4 0; -fx-border-color: #c16cda;">
            <Label text="Pesanan Selesai" style="-fx-text-fill: #7F8C8D; -fx-font-size: 11px; -fx-font-weight: 500;"/>
            <Label fx:id="lblSelesai" text="0" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e4581;" />
        </VBox>

        <VBox alignment="CENTER" prefWidth="220" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(155,89,182,0.2), 15, 0, 0, 6); -fx-border-width: 0 0 4 0; -fx-border-color: #9B59B6;">
            <Label text="Total Pendapatan" style="-fx-text-fill: #7F8C8D; -fx-font-size: 11px; -fx-font-weight: bold;"/>
            <Label fx:id="lblPendapatan" text="Rp 0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #9B59B6;" />
        </VBox>
    </FlowPane>

    <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);">
        <Label text="Aktivitas Terbaru" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #1e4581;"/>
        <Label fx:id="lblNama" text="Belum ada aktivitas terbaru" style="-fx-padding: 8 0 0 0; -fx-text-fill: #7F8C8D; -fx-font-size: 14px;" />
    </VBox>

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER" spacing="25" style="-fx-padding: 5;">
        <Button text="Kelola Data Pesanan" onAction="#handleKelolaPesanan"
                style="-fx-background-color: #30a8d4; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 35; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(48,168,212,0.3), 10, 0, 0, 4);" />

        <Button text="Riwayat Transaksi" onAction="#handleRiwayat"
                style="-fx-background-color: #c16cda; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 35; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(193,108,218,0.3), 10, 0, 0, 4);" />
    </HBox>
</VBox>